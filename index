<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>خريطة عماير مكة</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    :root{
      --bg:#f4f6f8; --card:#fff; --text:#1f2937; --muted:#6b7280; --line:#e5e7eb; --main:#0f766e;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:Tahoma,Arial,sans-serif;background:var(--bg);color:var(--text)}
    .app{display:grid;grid-template-columns:360px 1fr;gap:14px;height:100vh;padding:14px}
    .sidebar,.mapwrap{background:var(--card);border:1px solid var(--line);border-radius:18px;overflow:hidden;min-height:0}
    .sidebar{display:flex;flex-direction:column;min-height:0}
    .head{padding:18px 18px 10px;border-bottom:1px solid var(--line)}
    h1{margin:0 0 8px;font-size:24px}
    .sub{color:var(--muted);font-size:13px;line-height:1.7}
    .controls{padding:12px 16px;border-bottom:1px solid var(--line);display:grid;gap:10px}
    input,select{width:100%;border:1px solid #d1d5db;border-radius:12px;padding:12px;font-size:14px;background:#fff}
    .row,.stats{display:flex;gap:8px;flex-wrap:wrap}
    .badge,.toggle{
      border:1px solid var(--line);background:#fff;color:var(--text);
      border-radius:999px;padding:8px 12px;font-size:13px;cursor:pointer
    }
    .badge{cursor:default}
    .toggle.active{background:var(--main);color:#fff;border-color:var(--main)}
    .list{overflow:auto;padding:8px}
    .card{border:1px solid var(--line);border-radius:16px;padding:12px;margin:8px;background:#fff;cursor:pointer}
    .card:hover,.card.active{box-shadow:0 8px 18px rgba(15,118,110,.12)}
    .title{font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .pill{display:inline-block;border-radius:999px;padding:4px 8px;font-size:11px;font-weight:700;background:rgba(255,255,255,.85);border:1px solid rgba(0,0,0,.08)}
    .meta{color:#334155;font-size:12px;line-height:1.9}
    .actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .btn{display:inline-block;text-decoration:none;border-radius:10px;padding:8px 10px;font-size:13px;border:1px solid rgba(0,0,0,.08);color:var(--text);background:rgba(255,255,255,.92);cursor:pointer}
    .btn.primary{background:#0f766e;color:#fff;border-color:#0f766e}
    .mapbar{padding:12px 14px;border-bottom:1px solid var(--line);display:flex;gap:8px;align-items:center;justify-content:space-between;flex-wrap:wrap}
    .mapnote,.status{color:var(--muted);font-size:12px}
    #map{height:calc(100vh - 84px);width:100%}
    .leaflet-popup-content{font-family:Tahoma,Arial,sans-serif;line-height:1.8}
    .label-marker{background:transparent;border:none}
    .label-wrap{display:flex;align-items:center;gap:6px;transform:translate(-50%,-50%);pointer-events:auto}
    .label-dot{width:14px;height:14px;border:2px solid #fff;border-radius:999px;box-shadow:0 2px 8px rgba(0,0,0,.22);flex:0 0 auto;background:#0f766e}
    .label-text{background:rgba(255,255,255,.97);border-radius:999px;padding:4px 8px;font-size:12px;font-weight:700;line-height:1.2;white-space:nowrap;box-shadow:0 4px 10px rgba(0,0,0,.08)}
    .mobile{display:none;padding:12px;gap:10px;background:var(--bg)}
    .mobile .grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px}
    .mobile .card{margin:0;padding:6px;border-radius:10px;min-height:66px}
    .mobile .title{margin:0 0 3px;align-items:flex-start;gap:5px}
    .mobile .title span:first-child{font-size:10px;line-height:1.15}
    .mobile .meta,.mobile .actions{display:none}
    .mobile-mini-actions{display:flex;gap:4px;flex-wrap:wrap;margin-top:5px}
    .mobile-mini-actions .btn{padding:3px 5px;font-size:8px;border-radius:7px}
    @media (max-width:900px){
      .app{display:flex;flex-direction:column;height:auto;padding:10px}
      .sidebar{display:none}
      .mapwrap{order:1}
      #map{height:62vh}
      .mobile{display:grid;order:2}
      .mapbar .right-tools{display:none}
      .label-text{font-size:11px;padding:3px 7px}
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="head">
        <h1>خريطة عماير مكة</h1>
        <div class="sub">مرتبطة بـ Google Sheet. إذا كانت الإحداثيات موجودة تستخدمها مباشرة، وإذا فاضية يحاول النظام استخراجها من الرابط.</div>
      </div>
      <div class="controls">
        <input id="search" placeholder="ابحث برقم العمارة أو المالك أو المستأجر أو مركز الضيافة">
        <select id="areaFilter"><option value="الكل">كل المناطق</option></select>
        <div class="row">
          <button class="toggle active" id="showBuilding">رقم العمارة</button>
          <button class="toggle" id="showHospitality">رقم الضيافة</button>
          <button class="toggle" id="fitBtn">ملاءمة الظاهر</button>
        </div>
        <div class="stats">
          <span class="badge">الظاهر الآن: <b id="visibleCount">0</b></span>
        </div>
        <div class="status" id="statusText">جارِ تحميل البيانات...</div>
      </div>
      <div class="list" id="list"></div>
    </aside>

    <main class="mapwrap">
      <div class="mapbar">
        <div class="mapnote">اضغط "تحديث الموقع" ثم اختر نقطة جديدة من الخريطة لحفظها في الشيت.</div>
        <div class="right-tools row">
          <button class="toggle active" id="mobileShowBuilding">رقم العمارة</button>
          <button class="toggle" id="mobileShowHospitality">رقم الضيافة</button>
          <button class="toggle" id="locateBtn">موقعي</button>
        </div>
      </div>
      <div id="map"></div>
    </main>

    <section class="mobile">
      <input id="searchMobile" placeholder="ابحث برقم العمارة أو المالك أو المستأجر أو مركز الضيافة">
      <select id="areaFilterMobile"><option value="الكل">كل المناطق</option></select>
      <div class="grid" id="mobileGrid"></div>
    </section>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    const API = "https://script.google.com/macros/s/AKfycbry3jVbbcbBVbG2ZYaU2jr-Zp-OG9UtJzZjK0zJSvGArmKxx8WBPFZSQBjERfcDhw-Q/exec";

    const map = L.map("map", { zoomControl: true });
    L.tileLayer("https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: "&copy; OpenStreetMap"
    }).addTo(map);

    const listEl = document.getElementById("list");
    const mobileGrid = document.getElementById("mobileGrid");
    const searchEl = document.getElementById("search");
    const searchMobileEl = document.getElementById("searchMobile");
    const areaFilterEl = document.getElementById("areaFilter");
    const areaFilterMobileEl = document.getElementById("areaFilterMobile");
    const visibleCountEl = document.getElementById("visibleCount");
    const statusText = document.getElementById("statusText");
    const fitBtn = document.getElementById("fitBtn");
    const showBuildingBtn = document.getElementById("showBuilding");
    const showHospitalityBtn = document.getElementById("showHospitality");
    const mobileShowBuildingBtn = document.getElementById("mobileShowBuilding");
    const mobileShowHospitalityBtn = document.getElementById("mobileShowHospitality");
    const locateBtn = document.getElementById("locateBtn");

    let buildings = [];
    let markers = [];
    let labelMode = "building";
    let userMarker = null;
    let userLatLng = null;
    let geoWatchId = null;
    let editMode = false;
    let editItem = null;
    let editPassword = "";

    function esc(v) {
      return String(v ?? "").replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s]));
    }

    function extractCoordsFromLink(link) {
      if (!link) return { lat: null, lng: null };
      const s = String(link).trim();
      const patterns = [
        /[?&]q=(-?\d+\.\d+),\s*(-?\d+\.\d+)/i,
        /@(-?\d+\.\d+),\s*(-?\d+\.\d+)/i,
        /!3d(-?\d+\.\d+)!4d(-?\d+\.\d+)/i,
        /search\/(-?\d+\.\d+)\s*,\s*(-?\d+\.\d+)/i,
        /search\/.*?(-?\d+\.\d+)\s*,\s*(-?\d+\.\d+)/i,
        /place\/(-?\d+\.\d+),\s*(-?\d+\.\d+)/i,
        /(-?\d{1,2}\.\d+)\s*,\s*(-?\d{1,3}\.\d+)/i
      ];
      for (const pat of patterns) {
        const m = s.match(pat);
        if (m) {
          const lat = Number(m[1]), lng = Number(m[2]);
          if (Number.isFinite(lat) && Number.isFinite(lng)) return { lat, lng };
        }
      }
      return { lat: null, lng: null };
    }

    function mapRow(row, index) {
      let lat = row.lat !== undefined && row.lat !== null && String(row.lat).trim() !== "" ? Number(row.lat) : null;
      let lng = row.lng !== undefined && row.lng !== null && String(row.lng).trim() !== "" ? Number(row.lng) : null;
      const link = String(row.link || "").trim();

      if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
        const ex = extractCoordsFromLink(link);
        lat = ex.lat;
        lng = ex.lng;
      }

      return {
        _index: index,
        _rowNumber: row._rowNumber,
        building_no: String(row.building_no || "").trim(),
        unified_contract_no: String(row.unified_contract_no || "").trim(),
        hospitality_center_no: String(row.hospitality_center_no || "").trim(),
        license_no: String(row.license_no || "").trim(),
        owner_building_name: String(row.owner_building_name || "").trim(),
        tenant_name: String(row.tenant_name || "").trim(),
        area: String(row.area || "").trim(),
        pilgrims_contract: String(row.pilgrims_contract || "").trim(),
        pilgrims_center: String(row.pilgrims_center || "").trim(),
        lat: lat,
        lng: lng,
        has_coords: Number.isFinite(lat) && Number.isFinite(lng),
        link: link || (Number.isFinite(lat) && Number.isFinite(lng) ? `https://www.google.com/maps?q=${lat},${lng}` : "")
      };
    }

    function labelText(item) {
      return labelMode === "hospitality" ? (item.hospitality_center_no || item.building_no) : item.building_no;
    }

    function markerIcon(item) {
      return L.divIcon({
        className: "label-marker",
        html: `<div class="label-wrap"><span class="label-dot"></span><span class="label-text">${esc(labelText(item))}</span></div>`,
        iconSize: [130, 24],
        iconAnchor: [18, 12],
        popupAnchor: [0, -10]
      });
    }

    function navUrl(lat, lng) {
      return `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;
    }

    function popupHtml(item) {
      return `
        <div style="font-weight:700;margin-bottom:6px;">عمارة رقم ${esc(item.building_no)}</div>
        <div style="font-size:12px;color:#4b5563;line-height:1.8;">
          المنطقة: ${esc(item.area)}<br>
          مركز الضيافة: ${esc(item.hospitality_center_no)}<br>
          رقم العقد الموحد: ${esc(item.unified_contract_no)}<br>
          رقم الترخيص: ${esc(item.license_no)}<br>
          المالك/اسم العمارة: ${esc(item.owner_building_name)}<br>
          المستأجر: ${esc(item.tenant_name)}<br>
          حجاج العقد: ${esc(item.pilgrims_contract)}<br>
          حجاج المركز: ${esc(item.pilgrims_center)}
        </div>
        <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;">
          <a href="${item.link}" target="_blank">فتح الموقع</a>
          ${item.has_coords ? `<a href="${navUrl(item.lat,item.lng)}" target="_blank">الملاحة</a>` : ``}
          <button class="btn" onclick="startEditByIndex(${item._index})">تحديث الموقع</button>
        </div>
      `;
    }

    function cardHtml(item) {
      return `
        <div class="title">
          <span>عمارة رقم ${esc(item.building_no)}</span>
          <span class="pill">${esc(item.area)}</span>
        </div>
        <div class="meta">
          مركز الضيافة: ${esc(item.hospitality_center_no)}<br>
          رقم العقد الموحد: ${esc(item.unified_contract_no)}<br>
          رقم الترخيص: ${esc(item.license_no)}<br>
          المالك/اسم العمارة: ${esc(item.owner_building_name)}<br>
          المستأجر: ${esc(item.tenant_name)}<br>
          حجاج العقد: ${esc(item.pilgrims_contract)}<br>
          حجاج المركز: ${esc(item.pilgrims_center)}
        </div>
        <div class="actions">
          <button class="btn" data-copy="info">نسخ المعلومات</button>
          <button class="btn" data-copy="location">نسخ الموقع</button>
          <button class="btn" data-edit="1">تحديث الموقع</button>
          ${item.has_coords ? `<a class="btn primary" target="_blank" href="${navUrl(item.lat,item.lng)}">الملاحة</a>` : ``}
        </div>
      `;
    }

    function bindCardActions(div, item) {
      const infoBtn = div.querySelector('[data-copy="info"]');
      const locBtn = div.querySelector('[data-copy="location"]');
      const editBtn = div.querySelector('[data-edit="1"]');

      if (infoBtn) infoBtn.addEventListener("click", e => {
        e.stopPropagation();
        copyText([
          `عمارة رقم ${item.building_no}`,
          `المنطقة: ${item.area}`,
          `مركز الضيافة: ${item.hospitality_center_no}`,
          `رقم العقد الموحد: ${item.unified_contract_no}`,
          `رقم الترخيص: ${item.license_no}`,
          `المالك/اسم العمارة: ${item.owner_building_name}`,
          `المستأجر: ${item.tenant_name}`,
          `حجاج العقد: ${item.pilgrims_contract}`,
          `حجاج المركز: ${item.pilgrims_center}`
        ].join("\n"), e.currentTarget);
      });

      if (locBtn) locBtn.addEventListener("click", e => {
        e.stopPropagation();
        copyText(item.has_coords ? `${item.lat},${item.lng}` : item.link, e.currentTarget);
      });

      if (editBtn) editBtn.addEventListener("click", e => {
        e.stopPropagation();
        startEdit(item);
      });
    }

    async function copyText(text, btn) {
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        ta.remove();
      }
      if (btn) {
        const old = btn.textContent;
        btn.textContent = "تم";
        setTimeout(() => btn.textContent = old, 900);
      }
    }

    function filtered(query = "") {
      const q = query.trim().toLowerCase();
      const selectedArea = areaFilterEl.value;
      return buildings.filter(item => {
        const areaOk = selectedArea === "الكل" || item.area === selectedArea;
        const text = `${item.building_no} ${item.owner_building_name} ${item.tenant_name} ${item.hospitality_center_no} ${item.license_no} ${item.unified_contract_no} ${item.area}`.toLowerCase();
        return areaOk && (!q || text.includes(q));
      });
    }

    const group = L.featureGroup().addTo(map);

    function clearMarkers() {
      markers.forEach(m => group.removeLayer(m));
      markers = [];
    }

    function rebuildMarkers() {
      clearMarkers();
      buildings.forEach(item => {
        if (!item.has_coords) return;
        const marker = L.marker([item.lat, item.lng], { icon: markerIcon(item) }).addTo(group);
        marker.item = item;
        marker.bindPopup(popupHtml(item));
        marker.on("click", () => highlightCard(item._index));
        markers.push(marker);
      });
    }

    function highlightCard(index) {
      document.querySelectorAll(".card").forEach(el => el.classList.toggle("active", Number(el.dataset.index) === index));
    }

    function openItem(item) {
      const marker = markers.find(m => m.item._index === item._index);
      if (marker) {
        map.setView([item.lat, item.lng], 17);
        marker.openPopup();
        highlightCard(item._index);
      } else if (item.link) {
        window.open(item.link, "_blank");
      }
    }

    function fitAll(items) {
      const withCoords = items.filter(x => x.has_coords);
      if (!withCoords.length) return;
      const bounds = L.latLngBounds(withCoords.map(x => [x.lat, x.lng]));
      map.fitBounds(bounds.pad(0.15));
    }

    function render() {
      const query = searchEl.value || searchMobileEl.value;
      const items = filtered(query);

      markers.forEach(marker => {
        const show = items.some(i => i._index === marker.item._index);
        if (show) {
          if (!group.hasLayer(marker)) group.addLayer(marker);
        } else {
          if (group.hasLayer(marker)) group.removeLayer(marker);
        }
      });

      listEl.innerHTML = "";
      items.forEach(item => {
        const div = document.createElement("div");
        div.className = "card";
        div.dataset.index = item._index;
        div.innerHTML = cardHtml(item);
        bindCardActions(div, item);
        div.addEventListener("click", e => { if (e.target.closest("a,button")) return; openItem(item); });
        listEl.appendChild(div);
      });

      mobileGrid.innerHTML = "";
      items.forEach(item => {
        const div = document.createElement("div");
        div.className = "card";
        div.dataset.index = item._index;
        div.innerHTML = `
          <div class="title">
            <span>${esc(item.building_no)} — ${esc(item.hospitality_center_no)}</span>
            <span class="pill">${esc(item.area)}</span>
          </div>
          <div class="mobile-mini-actions">
            <button class="btn" data-copy="info">نسخ</button>
            <button class="btn" data-copy="location">موقع</button>
            <button class="btn" data-edit="1">تحديث</button>
          </div>
        `;
        bindCardActions(div, item);
        div.addEventListener("click", e => { if (e.target.closest("button")) return; openItem(item); });
        mobileGrid.appendChild(div);
      });

      visibleCountEl.textContent = items.length;
    }

    function fillAreas() {
      const areas = [...new Set(buildings.map(x => x.area).filter(Boolean))].sort((a,b)=>a.localeCompare(b,'ar'));
      for (const select of [areaFilterEl, areaFilterMobileEl]) {
        select.innerHTML = '<option value="الكل">كل المناطق</option>';
        areas.forEach(area => {
          const opt = document.createElement("option");
          opt.value = area;
          opt.textContent = area;
          select.appendChild(opt);
        });
      }
    }

    function syncAreaFilters(value) {
      areaFilterEl.value = value;
      areaFilterMobileEl.value = value;
      render();
    }

    function setLabelMode(mode) {
      labelMode = mode;
      showBuildingBtn.classList.toggle("active", mode === "building");
      showHospitalityBtn.classList.toggle("active", mode === "hospitality");
      mobileShowBuildingBtn.classList.toggle("active", mode === "building");
      mobileShowHospitalityBtn.classList.toggle("active", mode === "hospitality");
      markers.forEach(marker => marker.setIcon(markerIcon(marker.item)));
    }

    function updateUserLocation(lat, lng, centerMap = false) {
      userLatLng = { lat, lng };
      if (!userMarker) {
        userMarker = L.circleMarker([lat, lng], {
          radius: 8, color: "#fff", weight: 3, fillColor: "#2563eb", fillOpacity: 1
        }).addTo(map).bindPopup("موقعك الحالي");
      } else {
        userMarker.setLatLng([lat, lng]);
      }
      if (centerMap) {
        map.setView([lat, lng], 15);
        userMarker.openPopup();
      }
    }

    function startLiveLocation(forceCenter = false) {
      if (!navigator.geolocation) {
        statusText.textContent = "المتصفح لا يدعم الموقع الحالي.";
        return;
      }

      navigator.geolocation.getCurrentPosition(
        pos => updateUserLocation(pos.coords.latitude, pos.coords.longitude, true),
        err => { console.log(err); statusText.textContent = "اسمح بإذن الموقع ليظهر موقعك الحالي."; },
        { enableHighAccuracy:true, timeout:15000, maximumAge:0 }
      );

      if (geoWatchId !== null) return;
      geoWatchId = navigator.geolocation.watchPosition(
        pos => updateUserLocation(pos.coords.latitude, pos.coords.longitude, forceCenter && !userLatLng),
        err => console.log(err),
        { enableHighAccuracy:true, maximumAge:5000, timeout:15000 }
      );
    }

    async function loadData() {
      statusText.textContent = "جارِ تحميل البيانات...";
      try {
        const res = await fetch(API + "?action=list");
        const data = await res.json();
        buildings = data.map(mapRow);
        fillAreas();
        rebuildMarkers();
        render();
        setLabelMode("building");
        fitAll(buildings);
        const ready = buildings.filter(x => x.has_coords).length;
        statusText.textContent = `تم تحميل ${buildings.length} عمارة، منها ${ready} بإحداثيات.`;
      } catch (e) {
        console.error(e);
        statusText.textContent = "تعذر تحميل البيانات.";
      }
    }

    function startEdit(item) {
      if (!item || !item._rowNumber) {
        alert("هذا السجل غير مرتبط بصف في الشيت");
        return;
      }
      const pwd = prompt("أدخل كلمة السر");
      if (!pwd) return;
      editMode = true;
      editItem = item;
      editPassword = pwd;
      alert("اضغط على الموقع الجديد في الخريطة");
    }

    function startEditByIndex(index) {
      const item = buildings.find(x => x._index === index);
      if (item) startEdit(item);
    }
    window.startEditByIndex = startEditByIndex;

    map.on("click", async e => {
      if (!editMode || !editItem) return;
      const lat = e.latlng.lat, lng = e.latlng.lng;
      try {
        const res = await fetch(API, {
          method:"POST",
          headers:{ "Content-Type":"application/json" },
          body: JSON.stringify({
            action:"updateLocation",
            rowNumber: editItem._rowNumber,
            lat: lat,
            lng: lng,
            password: editPassword
          })
        });
        const result = await res.json();
        if (!result.ok) {
          alert("فشل التحديث: " + (result.error || "خطأ"));
          editMode = false;
          editItem = null;
          editPassword = "";
          return;
        }
        editItem.lat = lat;
        editItem.lng = lng;
        editItem.has_coords = true;
        editItem.link = `https://www.google.com/maps?q=${lat},${lng}`;
        rebuildMarkers();
        render();
        alert("تم تحديث الموقع بنجاح");
      } catch {
        alert("تعذر حفظ التحديث");
      }
      editMode = false;
      editItem = null;
      editPassword = "";
    });

    areaFilterEl.addEventListener("change", ()=>syncAreaFilters(areaFilterEl.value));
    areaFilterMobileEl.addEventListener("change", ()=>syncAreaFilters(areaFilterMobileEl.value));
    searchEl.addEventListener("input", ()=>{ searchMobileEl.value = searchEl.value; render(); });
    searchMobileEl.addEventListener("input", ()=>{ searchEl.value = searchMobileEl.value; render(); });
    fitBtn.addEventListener("click", ()=>fitAll(filtered(searchEl.value || searchMobileEl.value)));
    showBuildingBtn.addEventListener("click", ()=>setLabelMode("building"));
    showHospitalityBtn.addEventListener("click", ()=>setLabelMode("hospitality"));
    mobileShowBuildingBtn.addEventListener("click", ()=>setLabelMode("building"));
    mobileShowHospitalityBtn.addEventListener("click", ()=>setLabelMode("hospitality"));
    locateBtn.addEventListener("click", ()=>startLiveLocation(true));

    window.addEventListener("load", async () => {
      await loadData();
      startLiveLocation(true);
    });
  </script>
</body>
</html>
